function doGet(e){try{var m=(e&&e.parameter&&e.parameter.email)?e.parameter.email.trim():'';if(!m)return HtmlService.createHtmlOutput(getFormPage()).setTitle('Email Signature Generator - '+CONFIG.COMPANY_NAME).setXFrameOptionsMode(HtmlService.XFrameOptionsMode.ALLOWALL);if(!isValidEmail(m))return HtmlService.createHtmlOutput(getErrorPage('Invalid email format.')).setTitle('Error');var u=getUserData(m);if(!u)return HtmlService.createHtmlOutput(getErrorPage('Employee not found: '+m)).setTitle('Not Found');return HtmlService.createHtmlOutput(getResultPage(generateSignature(u),u)).setTitle('Your Signature - '+u.name).setXFrameOptionsMode(HtmlService.XFrameOptionsMode.ALLOWALL)}catch(x){Logger.log(x.message);return HtmlService.createHtmlOutput(getErrorPage('Error: '+x.message)).setTitle('Error')}}
function authorize(){SpreadsheetApp.openById(CONFIG.SHEET_ID).getSheets()[0].getName();return'OK'}
function isValidEmail(e){return/^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(e)}
function getUserData(e){var s=SpreadsheetApp.openById(CONFIG.SHEET_ID).getSheets()[0],d=s.getDataRange().getValues();for(var i=1;i<d.length;i++)if(String(d[i][3]).toLowerCase().trim()===e.toLowerCase().trim())return{name:String(d[i][0]).trim(),title:String(d[i][1]).trim(),department:String(d[i][2]).trim(),email:String(d[i][3]).trim(),phone:formatPhone(d[i][4]),mobile:formatPhone(d[i][5]),extension:String(d[i][6]).trim()};return null}
function formatPhone(n){if(!n)return'';var p=String(n).trim();if(p&&!p.startsWith('+')&&/^[0-9]/.test(p))p='+'+p;return p}
