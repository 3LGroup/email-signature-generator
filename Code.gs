function getFormPage(){return'<!DOCTYPE html><html><head><meta charset="UTF-8"><meta name="viewport" content="width=device-width,initial-scale=1.0"><title>Email Signature Generator</title><style>*{box-sizing:border-box;margin:0;padding:0}body{font-family:Arial,sans-serif;background:linear-gradient(135deg,#667eea 0%,#764ba2 100%);min-height:100vh;display:flex;align-items:center;justify-content:center;padding:20px}.c{background:#fff;padding:40px;border-radius:16px;box-shadow:0 20px 60px rgba(0,0,0,.3);max-width:420px;width:100%;text-align:center}.l{max-width:180px;margin-bottom:20px}h1{color:#333;font-size:22px;margin-bottom:8px}.s{color:#666;font-size:14px;margin-bottom:25px}input{width:100%;padding:14px;border:2px solid #e0e0e0;border-radius:10px;font-size:15px;margin-bottom:15px;transition:all .3s}input:focus{outline:none;border-color:#667eea;box-shadow:0 0 0 3px rgba(102,126,234,.2)}button{width:100%;padding:14px;background:linear-gradient(135deg,#667eea,#764ba2);color:#fff;border:none;border-radius:10px;font-size:16px;font-weight:600;cursor:pointer;transition:transform .2s,box-shadow .2s}button:hover{transform:translateY(-2px);box-shadow:0 5px 20px rgba(102,126,234,.4)}.f{margin-top:20px;font-size:12px;color:#999}</style></head><body><div class="c"><img src="'+CONFIG.LOGO_URL+'" class="l" alt="Logo"><h1>Email Signature Generator</h1><p class="s">Enter your company email to generate your signature</p><form method="get"><input type="email" name="email" placeholder="your.name@3lines.com.sa" required><button type="submit">Generate Signature</button></form><p class="f">Contact IT if you need help</p></div></body></html>'}
function getResultPage(sig,u){return'<!DOCTYPE html><html><head><meta charset="UTF-8"><meta name="viewport" content="width=device-width,initial-scale=1.0"><title>Your Signature</title><style>*{box-sizing:border-box;margin:0;padding:0}body{font-family:Arial,sans-serif;background:#f0f2f5;padding:30px 20px}.cn{max-width:750px;margin:0 auto;background:#fff;border-radius:12px;box-shadow:0 4px 20px rgba(0,0,0,.1);overflow:hidden}.h{background:linear-gradient(135deg,#667eea,#764ba2);color:#fff;padding:25px;text-align:center}.h h1{font-size:20px;margin-bottom:5px}.h p{opacity:.9;font-size:14px}.co{padding:25px}.pv{background:#fff;border:1px solid #e0e0e0;border-radius:8px;padding:20px;margin:15px 0}.bt{display:inline-block;padding:12px 25px;background:#667eea;color:#fff;border:none;border-radius:8px;font-size:14px;font-weight:600;cursor:pointer;margin-right:10px;text-decoration:none;transition:all .3s}.bt:hover{background:#5a6fd6}.bt.ok{background:#28a745}.bo{background:#fff;color:#667eea;border:2px solid #667eea}.bo:hover{background:#667eea;color:#fff}.in{background:#f8f9fa;border-radius:8px;padding:20px;margin-top:20px}.in h3{color:#333;margin-bottom:12px;font-size:15px}.in ol{padding-left:20px;color:#555;line-height:1.9;font-size:14px}.bk{display:inline-block;margin-top:15px;color:#667eea;text-decoration:none;font-size:14px}</style></head><body><div class="cn"><div class="h"><h1>Hello, '+u.name+'!</h1><p>Your signature is ready</p></div><div class="co"><p style="font-size:14px;color:#333;margin-bottom:10px;font-weight:600">Preview:</p><div class="pv" id="sig">'+sig+'</div><button class="bt" id="copyBtn" onclick="copyIt()">Copy Signature</button><button class="bt bo" onclick="selectIt()">Select All</button><div class="in"><h3>How to use in Outlook:</h3><ol><li>Click "Copy Signature" above</li><li>Open Outlook \u2192 File \u2192 Options \u2192 Mail \u2192 Signatures</li><li>Click New, name it, then Ctrl+V to paste</li><li>Click OK to save</li></ol></div><a href="?" class="bk">\u2190 Generate another</a></div></div><script>function doSel(id){var s=document.getElementById(id),rng=document.createRange();rng.selectNodeContents(s);var q=window.getSelection();q.removeAllRanges();q.addRange(rng);return q}function copyIt(){var q=doSel("sig");try{document.execCommand("copy");var b=document.getElementById("copyBtn");b.textContent="Copied!";b.classList.add("ok");setTimeout(function(){b.textContent="Copy Signature";b.classList.remove("ok")},2000)}catch(e){alert("Press Ctrl+C")}q.removeAllRanges()}function selectIt(){doSel("sig")}</script></body></html>'}
